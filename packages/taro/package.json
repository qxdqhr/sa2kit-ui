{
  "name": "@animal-island-components-sa2kit/taro",
  "version": "0.0.1",
  "description": "Taro components for animal-island-components-sa2kit",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external @tarojs/components --external @tarojs/taro --external @animal-island-components-sa2kit/shared --external react --loader .png=dataurl --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@animal-island-components-sa2kit/shared": "workspace:*"
  },
  "peerDependencies": {
    "@tarojs/components": ">=4.0.0",
    "@tarojs/taro": ">=4.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@animal-island-components-sa2kit/tokens": "workspace:*",
    "@tarojs/components": "^4.1.1",
    "@tarojs/taro": "^4.1.1",
    "@types/react": "^18.3.18",
    "react": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.5.0",
    "typescript": "^5.7.3"
  }
}
